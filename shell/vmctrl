#!/bin/bash

# Source common VM configuration
source $(dirname "$0")/vm_config.sh

# Menu options (vmctrl specific)
chgexit='[EXIT (-_-) ]'
gotoup='[Go up <<<< ]'
sshvm='vm login'
killvm='vm close'
restartvm='vm restart'
moreinfo='vm info'
vmcore='save core'
vmsavelog='save log'
flush='[vm update]'
vmlog='vm log'
vmtop='[vm top]'


fun_parse_vms() {
	unset lines
	unset types
	unset ips
	unset uptime
	unset status
	unset sshs
	local i
	readarray -t lines < <(ps ux | grep ${qemu_prefix} | grep -v grep)
	count=${#lines[@]}
	for (( i=0; i<$count; i++))
	do
		types[$i]=`echo "${lines[i]}" | awk -F "system-" '{print $2}' | awk -F " " '{print $1}'`
		pids[$i]=`echo "${lines[i]}" | awk '{print $2}'`
		ips[$i]=`echo "${lines[i]}" | awk -F "IP=" '{print $2}' | awk -F " " '{print $1}'`
		ports[$i]=`echo "${lines[i]}" | awk -F "localhost:" '{print $2}' | awk -F "," '{print $1}'`
		uptime[$i]="0"
		sshs[$i]="0"
	done
}

fun_getvm() {
	fun_parse_vms
	echo -e "${YELLOW_COLOR}---------------------------------------------------------------------------"
	echo -e "You have ${RED_COLOR}$count${YELLOW_COLOR} virtual machines running >>"
	printf "%-15s| %-4s| %-10s| %-10s| %-12s| %-4s|\n" "Network" "Sel" "Arch" "PID" "UpTime" "SSH"
	for (( i=0; i<$count; i++))
	do
		num="$(( $i + 4 ))"
		printf "${CYAN_COLOR}%-15s${YELLOW_COLOR}|${CYAN_COLOR} %-4d${YELLOW_COLOR}| %-10s| %-10s| %-12s| %-4s|\n" \
			"${ips[$i]}" $num "${types[$i]}" "${pids[$i]}" "${uptime[$i]}" "${sshs[$i]}"
	done
	echo -e "${YELLOW_COLOR}---------------------------------------------------------------------------"
}

fun_getvmtop() {
	local i
	fun_parse_vms
	# Re-populate with uptime and ssh counts for top view
	for (( i=0; i<$count; i++))
	do
		uptime[$i]=`ps -o etime -p ${pids[$i]} | grep -v ELAPSED`
		sshs[$i]=`ps ux | grep "ssh " | grep -v grep | grep -v sshpass | grep ${ips[$i]} |wc -l`
	done
	printf "\033c" #clear terminal
	echo -e "${YELLOW_COLOR}---------------------------------------------------------------------------"
	echo -e "You have ${RED_COLOR}$count${YELLOW_COLOR} virtual machines running >>"
	printf "%-8s| %-15s| %-10s| %-10s| %-12s| %-4s|\n" "Staus" "Network" "Arch" "PID" "UpTime" "SSH"
	for (( i=0; i<$count; i++))
	do
		ping ${ips[$i]} -c 1 -W 1 > /dev/null
		if [ $? == 0 ] ;then
			status[$i]="Alive"
		else
			status[$i]="....."
			ping ${ips[$i]} -c 1 -W 1 > /dev/null && status[$i]="Alive"
		fi
		printf "%-8s| %-15s| %-10s| %-10s| %-12s| %-4d|\n" ${status[$i]} ${ips[$i]} \
			${types[$i]} ${pids[$i]} ${uptime[$i]} ${sshs[$i]}
	done
	echo -e "${YELLOW_COLOR}---------------------------------------------------------------------------"
}

# ńÖ╗ķÖåqemuńö¤µłÉvmcoreµ¢ćõ╗Č
fun_savecore() {
	local index=$1
	local datetag=$2
	local qemuport="localhost ${ports[$index]}"
	local tmpdir=/tmp/ll_tmp
	local tmpfile=${tmpdir}/qemu_vmcore.img
	local tailip=`echo ${ips[$index]} | awk -F "." '{print $4}'`
	local corefile=${CPATH}/qemu_vm_t${tailip}_${datetag}.core

	echo -e "${CYAN_COLOR}Start generate vmcore for ${ips[$index]}......"
	mkdir -p $tmpdir
	rm -f $tmpfile

	{
		sleep 0.5
		echo '{"execute": "qmp_capabilities"}'
		sleep 0.5
		echo '{"execute":"dump-guest-memory","arguments":{"paging":false,"protocol":"file:/tmp/ll_tmp/qemu_vmcore.img"}}'
		sleep 1
		echo -e '\035'
		sleep 0.5
		echo 'quit'
	}|telnet $qemuport

	if [ $? == 0 ] ;then
		cp $tmpfile $corefile
		rm -f $tmpfile
		echo -e "${CYAN_COLOR}Success generate vmcore: ${BLUE_COLOR}${corefile}"
		echo -e "${RES}"
	else
		echo -e "${RED_COLOR}Failed generate vmcore.${RES}"
	fi
}

fun_savelog() {
	local index=$1
	local datetag=$2
	local tailip=`echo ${ips[$index]} | awk -F "." '{print $4}'`
	logfile=`echo ${lines[$index]} | awk -F "serial file:" '{print $2}' | awk -F " " '{print $1}'`
	local vmlogfile=${CPATH}/qemu_vm_t${tailip}_${datetag}.log

	if [ -z $logfile ] ;then
		echo -e "${RED_COLOR}Virtual machine ${ips[$index]} log ${logfile} not exist."
	else
		cp $logfile $vmlogfile
		echo -e "${CYAN_COLOR}Success save log: ${BLUE_COLOR}${vmlogfile}"
	fi
	echo -e "${RES}"
}

# µĀ╣µŹ«ĶÖÜµŗ¤µ£║ńÜäkernelķĢ£ÕāÅÕī╣ķģŹksnapshotÕ┐½ńģ¦
fun_linkksnap() {
	local index=$1
	local datetag=$2
	local tailip=`echo ${ips[$index]} | awk -F "." '{print $4}'`
	local kimage=`echo ${lines[$index]} | awk -F "-kernel " '{print $2}' | awk -F " " '{print $1}'`
	local vmsnapshot=${CPATH}/qemu_vm_t${tailip}_${datetag}.ksnap
	unset snapdirs
	readarray -t snapdirs < <(ls `realpath $ksdir`)

	for element in ${snapdirs[@]}
	do
		[[ -d $ksdir/$element ]] || continue
		[[ -f $ksdir/$element/bzImage ]] || continue
		diff $ksdir/$element/bzImage $kimage >> /dev/null
		if [ $? == 0 ] ;then
			ln -s $ksdir/$element $vmsnapshot
			echo -e "${CYAN_COLOR}Success find ksnapshot: ${BLUE_COLOR}$ksdir/$element"
			return 0
		fi
	done
	echo -e "${RED_COLOR}Not find ksnapshot"
	return 1
}

fun_vmctrl() {
	local index=$1
	ping ${ips[$index]} -c 1 -W 1 > /dev/null
	if [ $? == 0 ] ;then
		status[$index]="Connect"
	else
		status[$index]="Disconn"
	fi
	sshs[$index]=`ps ux | grep "ssh " | grep -v grep | grep -v sshpass | grep ${ips[$index]} |wc -l`
	while true;do
		echo -e "${YELLOW_COLOR}---------------------------------------------------------------------------"
		echo -e "${YELLOW_COLOR}The virtual machine that you currently selected >>"
		printf "%-15s| %-10s| %-10s| %-12s| %-10s| %-4s|\n" "Network" "Arch" "PID" "UpTime" "Status" "SSH"
		printf "${CYAN_COLOR}%-15s${YELLOW_COLOR}| %-10s| %-10d| %-12s| %-10s| %-4d|\n" ${ips[$index]} \
			${types[$index]} ${pids[$index]} ${uptime[$index]} ${status[$index]} ${sshs[$index]}
		echo -e "${YELLOW_COLOR}---------------------------------------------------------------------------"
		echo -e "Plese enter operation number:"
		select vm in "${chgexit}" "${gotoup}" "${sshvm}" "${killvm}" "${moreinfo}" "${vmlog}" "${vmsavelog}" "${vmcore}";
		do
			case $vm in
				"${chgexit}")
					echo -e "${RES}"
					exit
					;;
				"${gotoup}")
					echo -e "${RES}"
					break 2
					;;
				"${sshvm}")
					if [ ${status[$index]} == "Connect" ] ;then
						echo -e "SSH ${ips[$index]}......"
						echo -e "${RES}"
						sshpass -p "root" ssh root@${ips[$index]} -o StrictHostKeyChecking=no
						if [ $? != 0 ] ;then
							echo -e "${RED_COLOR}SSH login ${ips[$index]} faild."
						fi
					else
						echo -e "${RED_COLOR}Can't connecting to ${ips[$index]}"
					fi
					echo -e "${RES}"
					break
					;;
				"${killvm}")
					local tailip=`echo ${ips[$index]} | awk -F "." '{print $4}'`
					vmmutil -o stop -i ${tailip}
					break 2
					;;
				"${moreinfo}")
					#sedõ╗ź" -"µØźÕłåķÜöõĖĆĶĪīõĖ║ÕżÜĶĪī, readarrayÕÅ»õ╗źõ╗źĶĪīµØźÕłåķÜöĶ»╗ÕÅ¢Õł░µĢ░ń╗ä
					readarray -t params < <(echo ${lines[$index]} | awk -F "qemu-" '{print $2}' | sed 's/ -/\n/g')
					echo -e "${BLUE_COLOR}---------------------------------------------------------------------------"
					echo -e "Virtual machine options >>"
					nparams=${#params[@]}
					for (( i=1; i<$nparams; i++))
					do
						echo "-${params[$i]}"
					done
					echo -e "${BLUE_COLOR}---------------------------------------------------------------------------"
					echo -e "${RES}"
					break
					;;
				"${vmlog}")
					echo -e "${RES}"
					unset logfile
					logfile=`echo ${lines[$index]} | awk -F "serial file:" '{print $2}' | awk -F " " '{print $1}'`
					if [ -z $logfile ] ;then
						echo -e "${RED_COLOR}Virtual machine ${ips[$index]} log ${logfile} not exist."
					else
						less $logfile
					fi
					echo -e "${RES}"
					break
					;;
				"${vmsavelog}")
					local datetag=`date '+%Y%m%d_%H%M%S'`
					fun_savelog $index $datetag
					break
					;;
				"${vmcore}")
					local datetag=`date '+%Y%m%d_%H%M%S'`
					fun_savecore $index $datetag
					fun_savelog $index $datetag
					fun_linkksnap $index $datetag
					break
					;;
		
				*)
					break
					;;
			esac
		done
	done
}

fun_vmtop() {
	local i
	while true;do
		fun_getvmtop
		for (( i=0; i<10; i++))
		do
			read -r -t 1 -N 1 input
				case $input in
				[eE]|[qQ])
				break 2
				;;
			esac
		done
	done
}

fun_main() {
	while true;do
	fun_getvm
	echo -e "Plese enter select number:"
	select vm in "${chgexit}" "${flush}" "${vmtop}" "${ips[@]}" ;
	do
		case $vm in
			"${chgexit}")
				echo -e "${RES}"
				exit
		;;
				"${flush}")
				echo -e "${RES}"
				break
		;;
				"${vmtop}")
				fun_vmtop
				echo -e "${RES}"
				break
		;;
			*)
				selectip=$vm 
				if [ -z $selectip ] ;then
					break
				fi
				for (( i=0; i<$count; i++)) 
				do
					if [ ${ips[$i]} = $selectip ] ;then
						fun_vmctrl $i
					fi	
				done
			break
		;;

	esac
	done
	done
}

fun_login() {
	local tail i n
	tail=$1
	if [[ $tail =~ ^[0-9]+$ ]] ;then
		fun_getvm
		n=${#ips[@]}
		for (( i=0; i<$n; i++))
		do
			if [ $ipprefix$tail == ${ips[$i]} ] ;then
				fun_vmctrl $i
				exit 0
			fi
		done
	else
		echo -e "tail ip in correct"
	fi
}


#main
if [ $# != 0 ] ; then
	fun_login $1
else
	fun_main
fi
